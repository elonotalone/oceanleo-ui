    "consumers:scan": "node scripts/scan-consumer-imports.mjs",
    "consumers:check": "node scripts/scan-consumer-imports.mjs --summary --check-exports",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --experimental-loader ./tests/ts-extension-loader.mjs --test tests/*.test.mjs",
    "build": "npm run build:css && npm run typecheck"
  },
  "exports": {
    ".": "./src/index.ts",
