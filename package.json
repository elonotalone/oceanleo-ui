    "./i18n/server": "./src/i18n/server.ts",
    "./i18n/messages/zh.json": "./src/i18n/messages/zh.json",
    "./i18n/messages/en.json": "./src/i18n/messages/en.json",
    "./theme": "./src/theme/index.ts",
