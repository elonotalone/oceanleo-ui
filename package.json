{
  "name": "@oceanleo/ui",
  "version": "0.171.0",
  "description": "OceanLeo 全家桶统一前端外壳 — 单一事实源（侧边栏/AI 模型市场/账户/设置/主题/SSO/网关）。所有 *.oceanleo.com 站（除 crm）共享此包。",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build:themes": "node scripts/gen-theme-css.mjs",
    "build:css": "node scripts/gen-theme-css.mjs && tailwindcss -i ./src/theme/_ui-input.css -o ./src/theme/ui.css --minify",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "build": "npm run build:css && npm run typecheck"
  },
  "exports": {
    ".": "./src/index.ts",
    "./shell": "./src/shell/index.ts",
    "./shell/selection-context": "./src/shell/selection-context.ts",
    "./org-canvas": "./src/shell/OrgCanvas.tsx",
    "./pages": "./src/pages/index.ts",
    "./ui": "./src/ui/index.tsx",
    "./lib": "./src/lib/index.ts",
    "./lib/auth": "./src/lib/auth/index.ts",
    "./lib/auth/middleware": "./src/lib/auth/middleware.ts",
    "./lib/auth/config": "./src/lib/auth/config.ts",
    "./lib/auth/client": "./src/lib/auth/client.ts",
    "./lib/auth/account": "./src/lib/auth/account.ts",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/server": "./src/i18n/server.ts",
    "./i18n/messages/zh.json": "./src/i18n/messages/zh.json",
    "./i18n/messages/en.json": "./src/i18n/messages/en.json",
    "./theme": "./src/theme/index.ts",
    "./theme/server": "./src/theme/server.ts",
    "./theme/globals.css": "./src/theme/globals.css",
    "./theme/ui.css": "./src/theme/ui.css",
    "./tailwind-preset": "./src/theme/tailwind-preset.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "@supabase/ssr": ">=0.5.0",
    "@supabase/supabase-js": ">=2.45.0",
    "@xyflow/react": ">=12",
    "next": ">=14",
    "next-intl": ">=3.22.0",
    "react": ">=18",
    "react-dom": ">=18",
    "xlsx": ">=0.20.3"
  },
  "peerDependenciesMeta": {
    "sonner": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xyflow/react": "^12.11.1",
    "next-intl": "^4.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "dependencies": {
    "@google/model-viewer": "^4.3.1",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-color": "^3.27.3",
    "@tiptap/extension-document": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-history": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-paragraph": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-text": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@types/turndown": "^5.0.6",
    "docx": "^9.7.1",
    "dompurify": "^3.4.12",
    "echarts": "^6.1.0",
    "exceljs": "^4.4.0",
    "fabric": "^6.9.1",
    "mammoth": "^1.12.0",
    "marked": "^16.4.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "pptx-preview": "^1.0.7",
    "pptxgenjs": "^3.12.0",
    "pptxtojson": "^2.0.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.4",
    "wavesurfer.js": "^7.12.10"
  }
}
