  ],
  "scripts": {
    "build:themes": "node scripts/gen-theme-css.mjs",
    "build:css": "node scripts/gen-theme-css.mjs && tailwindcss -i ./src/theme/_ui-input.css -o ./src/theme/ui.css --minify",
    "architecture:check": "node --experimental-strip-types scripts/check-domain-boundaries.mjs",
